# Copy to .env for local development, or copy the production values into Coolify.
# All keys load into config.settings.AppConfig. Never commit a filled .env.
APP_NAME=Outreach Assistant
DEBUG=true
LOG_LEVEL=info
PORT=8000

# Database
# Local default:
DATABASE_URL=sqlite:///./db/sdr.sqlite3
# Production on Coolify + Neon: use Neon's pooled connection string and sslmode=require.
# DATABASE_URL=postgresql://user:password@ep-cool-db.region.aws.neon.tech/neondb?sslmode=require
# POSTGRES_POOL_MIN_SIZE=1
# POSTGRES_POOL_MAX_SIZE=5
# POSTGRES_POOL_TIMEOUT_SECONDS=20

# AI providers. Configure at least one provider. Azure OpenAI is preferred for Azure-hosted production.
OPENAI_API_KEY=
# Optional OpenAI-compatible proxy such as LiteLLM. Leave blank for direct OpenAI.
# OPENAI_BASE_URL=https://your-litellm-host/v1

# Optional primary provider: Azure OpenAI. When all three are set, Azure is tried before OPENAI_API_KEY.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_WIRE_API=chat_completions

# Optional: Fallback AI providers for better reliability
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=

# Langfuse Observability
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Clerk authentication. Required for the FastAPI backend and static frontend.
CLERK_SECRET_KEY=
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# Email transport. Use mailbox for connected SMTP/IMAP mailboxes like info@company.com.
EMAIL_PROVIDER=agentmail
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
# DEFAULT_MAILBOX_ID=
# RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM_EMAIL=Market Hacks <sdr@outreach.markethacks.co.ke>
# RESEND_REPLY_TO=sdr@outreach.markethacks.co.ke
# RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret

# Optional direct CRM lead import
# CRM_PROVIDER=hubspot
# CRM_API_KEY=pat-na1-...
# CRM_BASE_URL=https://api.hubapi.com

# Optional lead discovery providers. Keep mock fallback enabled only for local demos.
# APOLLO_API_KEY=your_apollo_master_api_key
# PDL_API_KEY=your_people_data_labs_key
# PDL_MAX_SEARCH_SIZE=10
# TAVILY_API_KEY=your_tavily_key
LEAD_SCOUT_PROVIDER_COOLDOWN_SECONDS=900
# Local/demo default. Production should set false unless mock leads are explicitly desired.
LEAD_SCOUT_MOCK_FALLBACK_ENABLED=true

# Multi-tenant admin/onboarding controls
# Comma-separated Clerk user emails allowed to create customer organizations.
PLATFORM_OWNER_EMAILS=owner@example.com
PLATFORM_ORGANIZATION_ID=1
# Cache non-secret Clerk user profile enrichment after JWT verification.
# Set to 0 to disable if immediate Clerk profile changes must be reflected.
# CLERK_USER_CACHE_TTL_SECONDS=300
# CLERK_USER_ENRICHMENT_TIMEOUT_SECONDS=5
# CLERK_USER_ENRICHMENT_CIRCUIT_COOLDOWN_SECONDS=30
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAILBOX_ENCRYPTION_KEY=
# OAuth mailbox connections. Configure these before exposing Google/Microsoft
# connect buttons to tenants. Callback URLs:
# http://localhost:8000/api/mailboxes/oauth/gmail/callback
# http://localhost:8000/api/mailboxes/oauth/microsoft/callback
# MAILBOX_OAUTH_STATE_SECRET=replace-with-long-random-secret
# MAILBOX_OAUTH_FRONTEND_REDIRECT_URL=http://localhost:3000/mailboxes
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_TENANT=common

# Model parameters for email monitor (intent and response agents)
LLM_ROUTING_MODE=quality_first
# quality_first keeps Azure/OpenAI ahead for production reliability.
# balanced is recommended for normal production cost control.
# cost_optimized lets low-risk/classification/review agents try cheaper capable fallbacks first.
INTENT_MODEL=gpt-4o-mini
INTENT_TEMPERATURE=0.1
INTENT_MAX_TOKENS=100

RESPONSE_MODEL=gpt-4o-mini
RESPONSE_TEMPERATURE=0.7
RESPONSE_MAX_TOKENS=800

# Optional per-provider fallback model overrides. Keep these aligned with config/llm_pricing.json.
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=gpt-oss-120b
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_META_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_LLAMA_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_DEEPSEEK_MODEL=qwen/qwen-2-7b-instruct:free
OPENROUTER_GOOGLE_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free
OPENROUTER_AUTO_MODEL=openrouter/free

# Organization BYOK switch. Plan must also allow BYOK before tenant keys are used.
# platform_first = platform keys first, then org keys.
# organization_first = org keys first, then platform keys.
# organization_only = org keys only; missing/invalid org keys fail closed.
ORGANIZATION_LLM_KEYS_ENABLED=false
ORGANIZATION_LLM_PROVIDER_MODE=platform_first

# Optional for single-instance Docker/Coolify deployments. Prefer running
# scripts/apply_postgres_migrations.py separately for shared production DBs.
APPLY_DB_MIGRATIONS_ON_STARTUP=false

# Background worker startup staggering helps local/serverless Postgres avoid
# pool contention immediately after boot.
# SCHEDULED_SENDER_INITIAL_DELAY_SECONDS=5
# MAILBOX_SYNC_INITIAL_DELAY_SECONDS=15

# Optional outreach tuning (same AppConfig; see config/settings.py)
# MAX_EMAILS_PER_LEAD=5
# MAX_WORDS_PER_EMAIL=200
# TONE=professional
# FORBIDDEN_PHRASES=guaranteed ROI,100% guarantee,no risk
RATE_LIMIT_REQUESTS_PER_MINUTE=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Global default. The two pipeline-specific settings below override this when set.
REQUIRE_HUMAN_APPROVAL=true
# Optional scheduler secret. Use as X-Cron-Secret when EventBridge/cron calls due-work endpoints.
# CRON_SECRET=replace-with-a-long-random-secret
# WEBHOOK_SECRET=replace-with-a-long-random-secret
# In-process scheduled email sender. Keep enabled for local/dev. In multi-worker production,
# prefer an external cron/Azure Container Apps Job/Azure Function timer hitting
# POST /api/scheduled-emails/send-due with X-Cron-Secret.
SCHEDULED_SENDER_ENABLED=true
SCHEDULED_SENDER_INTERVAL_SECONDS=30
SCHEDULED_SENDER_INITIAL_DELAY_SECONDS=5
SCHEDULED_SENDER_BATCH_SIZE=50
SCHEDULED_SENDER_RETRY_DELAY_SECONDS=300
SCHEDULED_SENDER_MAX_ATTEMPTS=3
# SMTP/IMAP mailbox monitoring endpoint defaults. Local testing can override
# MAILBOX_SYNC_MARK_SEEN=false when you intentionally want messages to stay unread.
# Production should keep mark-seen true and wait false.
MAILBOX_SYNC_DEFAULT_LIMIT=10
# Set true locally only when you want automatic polling while uvicorn is running.
# Keep false for multi-replica production and use one external scheduler instead.
MAILBOX_SYNC_ENABLED=false
MAILBOX_SYNC_MARK_SEEN=true
MAILBOX_SYNC_WAIT=false
MAILBOX_SYNC_INTERVAL_SECONDS=300
MAILBOX_SYNC_INITIAL_DELAY_SECONDS=15
MAILBOX_CONNECTION_TIMEOUT_SECONDS=15
# Outreach campaign approval can also be controlled per campaign with auto_approve_drafts.
# REQUIRE_OUTREACH_HUMAN_APPROVAL=true
# Email monitoring replies: true saves approved responses to Drafts, false sends immediately.
# REQUIRE_EMAIL_MONITOR_HUMAN_APPROVAL=true

# Production/Coolify checklist:
# DEBUG=false
# DATABASE_URL=postgresql://...neon.tech/...?...sslmode=require
# CORS_ORIGINS=https://your-frontend-domain.com
# NEXT_PUBLIC_API_URL=https://your-backend-domain.com
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=...
# CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
# SCHEDULED_SENDER_ENABLED=false     # if more than one backend replica
# MAILBOX_SYNC_ENABLED=false         # if more than one backend replica
# APPLY_DB_MIGRATIONS_ON_STARTUP=false
# LEAD_SCOUT_MOCK_FALLBACK_ENABLED=false
