# Copy to .env. All keys load into config.settings.AppConfig (monitor, outreach, DB).
APP_NAME=Outreach Assistant
DEBUG=true
LOG_LEVEL=info

# SQLite: use one URL. Outreach bootstrap defaults to db/sdr.sqlite3 if unset in code;
# you can override explicitly:
# DATABASE_URL=sqlite:///./db/sdr.sqlite3
DATABASE_URL=sqlite:///./db/sdr.sqlite3

OPENAI_API_KEY=your_openai_api_key

# Optional primary provider: Azure OpenAI. When all three are set, Azure is tried before OPENAI_API_KEY.
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_WIRE_API=chat_completions

# Frontend (Next static build): same Clerk app as CLERK_JWKS_URL / secret on App Runner.
# Copy the Publishable key from Clerk Dashboard → API Keys (starts with pk_test_ or pk_live_).
# Loaded automatically from this file when you run `npm run build` in frontend/.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# NEXT_PUBLIC_API_URL=https://your-api-host.example.com

# Optional: Fallback AI providers for better reliability
# OPENROUTER_API_KEY=your_openrouter_key
# CEREBRAS_API_KEY=your_cerebras_key  
# GROQ_API_KEY=your_groq_key

AGENTMAIL_API_KEY=your_agentmail_api_key
AGENTMAIL_INBOX_ID=your_agentmail_inbox_id

# Email transport. Use mailbox for connected SMTP/IMAP mailboxes like info@company.com.
EMAIL_PROVIDER=agentmail
# DEFAULT_MAILBOX_ID=
# RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM_EMAIL=Market Hacks <sdr@outreach.markethacks.co.ke>
# RESEND_REPLY_TO=sdr@outreach.markethacks.co.ke
# RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret

# Optional direct CRM lead import
# CRM_PROVIDER=hubspot
# CRM_API_KEY=pat-na1-...
# CRM_BASE_URL=https://api.hubapi.com

# Multi-tenant admin/onboarding controls
# Comma-separated Clerk user emails allowed to create customer organizations.
PLATFORM_OWNER_EMAILS=owner@example.com
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAILBOX_ENCRYPTION_KEY=

# Model parameters for email monitor (intent and response agents)
INTENT_MODEL=gpt-4o-mini
INTENT_TEMPERATURE=0.1
INTENT_MAX_TOKENS=100

RESPONSE_MODEL=gpt-4o-mini
RESPONSE_TEMPERATURE=0.7
RESPONSE_MAX_TOKENS=800

# Optional outreach tuning (same AppConfig; see config/settings.py)
# MAX_EMAILS_PER_LEAD=5
# MAX_WORDS_PER_EMAIL=200
# TONE=professional
# FORBIDDEN_PHRASES=guaranteed ROI,100% guarantee,no risk
RATE_LIMIT_REQUESTS_PER_MINUTE=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Global default. The two pipeline-specific settings below override this when set.
REQUIRE_HUMAN_APPROVAL=true
# Optional scheduler secret. Use as X-Cron-Secret when EventBridge/cron calls due-work endpoints.
# CRON_SECRET=replace-with-a-long-random-secret
# In-process scheduled email sender. Keep enabled for local/dev. In multi-worker production,
# prefer an external cron hitting POST /api/scheduled-emails/send-due with X-Cron-Secret.
SCHEDULED_SENDER_ENABLED=true
SCHEDULED_SENDER_INTERVAL_SECONDS=30
SCHEDULED_SENDER_BATCH_SIZE=50
SCHEDULED_SENDER_RETRY_DELAY_SECONDS=300
SCHEDULED_SENDER_MAX_ATTEMPTS=3
# Outreach campaign approval can also be controlled per campaign with auto_approve_drafts.
# REQUIRE_OUTREACH_HUMAN_APPROVAL=true
# Email monitoring replies: true saves approved responses to Drafts, false sends immediately.
# REQUIRE_EMAIL_MONITOR_HUMAN_APPROVAL=true
