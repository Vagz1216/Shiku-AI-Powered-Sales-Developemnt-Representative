# Shiku SDR Azure production environment template.
# Do not commit a filled copy. Put secret values in Azure Container Apps secrets,
# Azure Key Vault, or GitHub environment secrets as appropriate.

# Backend runtime: Coolify on Azure / Azure Container Apps
APP_NAME=Shiku SDR
DEBUG=false
LOG_LEVEL=info
PORT=8000

# Neon PostgreSQL. Use the pooled connection string for serverless Postgres.
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST.neon.tech/DB_NAME?sslmode=require
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=5
POSTGRES_POOL_TIMEOUT_SECONDS=20

# Browser origins allowed to call FastAPI.
# Replace with the production frontend URL and any custom domain.
CORS_ORIGINS=https://YOUR_FRONTEND_DOMAIN
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# AI provider. Prefer Azure OpenAI in Azure-hosted production when available.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR_AZURE_OPENAI_RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_WIRE_API=chat_completions

# Optional fallback providers. Leave blank unless intentionally configured.
OPENAI_API_KEY=
# Optional OpenAI-compatible proxy such as LiteLLM. Leave blank for direct OpenAI.
OPENAI_BASE_URL=
OPENROUTER_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=

# LLM routing. quality_first preserves the Azure/OpenAI production hierarchy.
# balanced is recommended for normal production cost control.
# cost_optimized lets low-risk structured tasks try cheaper capable fallbacks first.
LLM_ROUTING_MODE=quality_first
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=gpt-oss-120b
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_META_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_LLAMA_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_DEEPSEEK_MODEL=qwen/qwen-2-7b-instruct:free
OPENROUTER_GOOGLE_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free
OPENROUTER_AUTO_MODEL=openrouter/free

# Organization BYOK switch. Plan must also allow BYOK before tenant keys are used.
# platform_first = platform keys first, then org keys.
# organization_first = org keys first, then platform keys.
# organization_only = org keys only; missing/invalid org keys fail closed.
ORGANIZATION_LLM_KEYS_ENABLED=false
ORGANIZATION_LLM_PROVIDER_MODE=platform_first

# Optional for single-instance Docker/Coolify deployments. Prefer GitHub Actions
# or a one-off migration job for multi-replica Azure production deployments.
APPLY_DB_MIGRATIONS_ON_STARTUP=false

# Authentication. Values come from Clerk.
CLERK_SECRET_KEY=
CLERK_JWKS_URL=https://YOUR_CLERK_DOMAIN/.well-known/jwks.json
CLERK_USER_CACHE_TTL_SECONDS=300
CLERK_USER_ENRICHMENT_TIMEOUT_SECONDS=5
CLERK_USER_ENRICHMENT_CIRCUIT_COOLDOWN_SECONDS=30
PLATFORM_OWNER_EMAILS=owner@example.com
PLATFORM_ORGANIZATION_ID=1

# Email provider. Choose one provider path and leave unused provider secrets blank.
EMAIL_PROVIDER=agentmail
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=

# Resend path, if EMAIL_PROVIDER=resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Shiku <sdr@yourdomain.com>
RESEND_REPLY_TO=sdr@yourdomain.com
RESEND_WEBHOOK_SECRET=

# Connected mailbox path, if EMAIL_PROVIDER=mailbox.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MAILBOX_ENCRYPTION_KEY=
DEFAULT_MAILBOX_ID=
MAILBOX_OAUTH_STATE_SECRET=
MAILBOX_OAUTH_FRONTEND_REDIRECT_URL=https://YOUR_FRONTEND_DOMAIN/mailboxes
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common

# Webhook and scheduler hardening.
WEBHOOK_SECRET=
CRON_SECRET=
REQUIRE_HUMAN_APPROVAL=true
REQUIRE_OUTREACH_HUMAN_APPROVAL=true
REQUIRE_EMAIL_MONITOR_HUMAN_APPROVAL=true

# In multi-replica production, keep the in-process scheduler disabled and use
# an Azure Container Apps Job / Azure Function timer to call due-work endpoints.
SCHEDULED_SENDER_ENABLED=false
SCHEDULED_SENDER_INTERVAL_SECONDS=30
SCHEDULED_SENDER_BATCH_SIZE=50
SCHEDULED_SENDER_RETRY_DELAY_SECONDS=300
SCHEDULED_SENDER_MAX_ATTEMPTS=3

# SMTP/IMAP mailbox monitoring. The external scheduler should POST
# /api/mailboxes/sync-due with X-Cron-Secret. Keep wait=false so Azure cron
# calls return immediately while the backend processes unread replies.
MAILBOX_SYNC_DEFAULT_LIMIT=10
MAILBOX_SYNC_ENABLED=false
MAILBOX_SYNC_MARK_SEEN=true
MAILBOX_SYNC_WAIT=false
MAILBOX_SYNC_INTERVAL_SECONDS=300
MAILBOX_SYNC_INITIAL_DELAY_SECONDS=15
MAILBOX_CONNECTION_TIMEOUT_SECONDS=15

# Optional integrations.
CRM_PROVIDER=
CRM_API_KEY=
CRM_BASE_URL=
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=

# Lead discovery providers. Do not enable mock fallback in production unless
# you explicitly want simulated candidates returned to users.
APOLLO_API_KEY=
PDL_API_KEY=
PDL_MAX_SEARCH_SIZE=10
TAVILY_API_KEY=
LEAD_SCOUT_PROVIDER_COOLDOWN_SECONDS=900
LEAD_SCOUT_MOCK_FALLBACK_ENABLED=false

# Frontend build: Azure Static Web Apps / GitHub Actions.
# These are public browser values, not backend secrets.
NEXT_PUBLIC_API_URL=https://YOUR_BACKEND_DOMAIN
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# GitHub Actions deployment configuration. Store these as GitHub environment
# variables/secrets, not as backend runtime environment variables.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_REGISTRY_LOGIN_SERVER=YOUR_REGISTRY.azurecr.io
AZURE_CONTAINER_APP_NAME=
AZURE_STATIC_WEB_APPS_API_TOKEN=
