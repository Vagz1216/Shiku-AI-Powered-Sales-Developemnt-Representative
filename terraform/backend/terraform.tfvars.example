# Copy to terraform.tfvars (gitignored). Fill from terraform/database outputs + your .env / secrets store.

aws_region = "us-west-2"

cluster_arn = "arn:aws:rds:us-west-2:ACCOUNT_ID:cluster:sdr-..."
secret_arn  = "arn:aws:secretsmanager:us-west-2:ACCOUNT_ID:secret:sdr-aurora-credentials-..."
db_name     = "sdr"

# --- Primary + fallback AI (matches config/settings.py) ---
openai_api_key      = ""
openai_tracing_key  = "" # Optional; separate key for OpenAI tracing export (main.py). Omit if unused.
groq_api_key        = "" # Optional comma-separated keys for rotation
cerebras_api_key    = ""
openrouter_api_key  = ""

# --- Email + integrations ---
agentmail_api_key   = ""
agentmail_inbox_id  = ""
composio_api_key    = ""
composio_user_id    = "" # Optional Composio session user id

# --- Auth (frontend API routes) ---
clerk_jwks_url      = "https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json"
clerk_secret_key    = ""
# Frontend static build needs the Publishable key (Dashboard → API Keys), not configured here:
# put NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY in repo root .env or frontend/.env.local

# --- Webhooks + browser ---
webhook_secret      = "" # Match AgentMail / provider webhook HMAC secret
# After CloudFront is live, set to your HTTPS site origin(s), comma-separated.
cors_origins        = "https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net"

# --- Optional app tuning (see config/settings.py for names and defaults) ---
# Same keys as env vars: INTENT_MODEL, RESPONSE_MODEL, OUTREACH_MODEL, REQUIRE_HUMAN_APPROVAL,
# DAILY_EMAIL_LIMIT, USE_DUMMY_DATA, MAX_EMAILS_PER_LEAD, etc.
extra_runtime_environment_variables = {
  # "INTENT_MODEL"           = "gpt-4o-mini"
  # "REQUIRE_HUMAN_APPROVAL" = "false"
  # "DATA_SOURCE"            = "DB" # lead_service optional override
}
